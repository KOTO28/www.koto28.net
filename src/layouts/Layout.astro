---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Background from "../components/layout/Background.astro";

type Props = {
  title?: string;
  fullWidth?: boolean;
};

const { title = "", fullWidth = false }: Props = Astro.props;

let pageTitle = "KOTO28";

if (title) {
  pageTitle += ` | ${title}`;
}
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <Font cssVariable="--font-noto-sans-jp" />
  </head>
  <body>
    <Header />
    <main class={fullWidth ? "full-width" : "centered"}>
      <slot />
    </main>
    <Footer />
    <Background />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100vw;
    height: 100vh;
  }

  body {
    display: flex;
    flex-direction: column;
    color: var(--text-color);
    font-family: var(--font-noto-sans-jp), sans-serif;
  }

  main {
    flex-grow: 1;
  }

  .centered {
    max-width: 1000px;
    margin: 0 auto;
    margin-left: max(100px, (100% - 1000px) /2);
  }
  .full-width {
    width: 100%;
    margin: 0;
  }
</style>
